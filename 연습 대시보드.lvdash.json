  "datasets": [
    {
      "name": "bced5237",
      "displayName": "trips",
      "queryLines": [
        "SELECT\n",
        "  DATE_FORMAT(tpep_pickup_datetime, 'yyyy-MM') AS month,\n",
        "  COUNT(*) AS trip_count\n",
        "FROM samples.nyctaxi.trips\n",
        "GROUP BY month\n",
        "ORDER BY month"
      ]
    }
  ],
